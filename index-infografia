    <script>
        lucide.createIcons();

        function goToSlide(slideId) {
            const slides = document.querySelectorAll('.slide');
            slides.forEach(slide => slide.classList.remove('active'));
            const target = document.getElementById(slideId);
            if(target) {
                target.classList.add('active');
                target.scrollTop = 0;
            }
        }
    </script>
