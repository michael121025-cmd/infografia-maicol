    <style>
        :root {
            --primary: #0A2E66;
            --accent: #3F79C7;
            --highlight: #6FA4E8;
            --dark-bg: #081F45;
            --text-primary: #F2F5F9;
            --text-secondary: #B8C2D1;
            --cards: #0F2F5C;
            --hover: #4F8FE8;
            --separators: #D9E1EC;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--dark-bg);
            color: var(--text-primary);
            overflow: hidden;
            height: 100vh;
        }

        h1, h2, h3 { font-family: 'Poppins', sans-serif; }

        /* Estructura de Slides */
        .slide {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: none;
            padding: 2rem;
            overflow-y: auto;
            background-color: var(--dark-bg);
        }

        .slide.active {
            display: flex;
            flex-direction: column;
            animation: fadeIn 0.5s ease-out forwards;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: scale(0.98); }
            to { opacity: 1; transform: scale(1); }
        }

        .hero-photo {
            width: 170px;
            height: 170px;
            border-radius: 50%;
            overflow: hidden;
            border: 3px solid white;
            box-shadow: 0 4px 20px rgba(0,0,0,0.4);
            margin: 1.5rem auto;
            flex-shrink: 0;
        }

        .hero-photo img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transform: scale(1.1);
        }

        .dashboard-card {
            background: var(--cards);
            border-radius: 1.5rem;
            transition: all 0.3s ease;
            cursor: pointer;
            border: 1px solid rgba(255,255,255,0.05);
            display: flex;
            flex-direction: column;
            overflow: hidden; 
        }

        .dashboard-card:hover {
            background: #163a75;
            transform: translateY(-5px);
            border-color: var(--highlight);
        }

        .family-section {
            background: #F2F5F9;
            border-radius: 2.5rem;
            padding: 2.5rem;
            color: var(--primary);
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
        }

        .text-wrap-safe {
            white-space: normal !important;
            word-wrap: break-word !important;
            overflow-wrap: break-word !important;
        }

        /* Imágenes circulares con centrado forzado y mejora de nitidez */
        .circle-frame {
            width: 115px;
            height: 115px;
            border-radius: 50%;
            overflow: hidden;
            border: 3px solid white;
            margin: 0 auto 1.25rem auto;
            background: #e2e8f0;
            display: block;
            flex-shrink: 0;
            box-shadow: 0 8px 15px rgba(0,0,0,0.1);
        }

        .circle-frame img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transform: scale(1.05);
            image-rendering: -webkit-optimize-contrast; /* Mejora resolución percibida */
        }

        .btn-nav {
            background: var(--accent);
            color: white;
            padding: 0.75rem 2rem;
            border-radius: 9999px;
            font-weight: 600;
            transition: all 0.3s;
            flex-shrink: 0;
        }

        .btn-nav:hover {
            background: var(--hover);
            box-shadow: 0 10px 20px rgba(79, 143, 232, 0.3);
        }

        .timeline-container {
            position: relative;
            padding-left: 3rem;
        }

        .timeline-line {
            position: absolute;
            left: 11px;
            top: 0;
            bottom: 0;
            width: 2px;
            background: linear-gradient(to bottom, var(--highlight), transparent);
        }

        .timeline-dot {
            position: absolute;
            left: 3px;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: var(--highlight);
            border: 4px solid var(--dark-bg);
            z-index: 10;
        }
    </style>
</head>
